{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/log.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Skill",
      "WebSearch",
      "WebFetch",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npm run build:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run preview:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run lint:fix:*)",
      "Bash(npm run lint:ci:*)",
      "Bash(npm run format:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm test:*)",
      "Bash(npm run test:browser:*)",
      "Bash(npm run test:visual:update:*)",
      "Bash(npm run test:watch:*)",
      "Bash(npm run mutation:*)",
      "Bash(npm run smoke:*)",
      "Bash(npm run audit:*)",
      "Bash(npm run preflight:*)",
      "Bash(npx biome:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(npx playwright:*)",
      "Bash(npx vite:*)",
      "Bash(node verify.mjs:*)",
      "Bash(node scripts/audit-drift.mjs:*)",
      "Bash(node scripts/preflight.mjs:*)",
      "Bash(node scripts/mutation-probe.mjs:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git branch:*)",
      "Bash(git config core.hooksPath:*)",
      "Bash(python3 tools/scan_staged.py:*)"
    ]
  }
}
